# VitaSage AI — Backend Environment Variables
# Copy this to .env and fill in your values

# PostgreSQL connection string from Neon.tech
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Strong random secret for JWT tokens (generate with: openssl rand -hex 32)
JWT_SECRET=your-very-strong-secret-key-here

# Token expiry in hours
JWT_EXPIRE_HOURS=8

# Comma-separated list of allowed frontend origins (your Vercel URL)
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173

# Secret for registering new hospitals (keep private)
REGISTER_SECRET=vitasage-bootstrap-secret
